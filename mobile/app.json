{
  "expo": {
    "name": "Veor Collection",
    "slug": "veor-collection",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "package": "com.veorcollection.app",
      "versionCode": 1,
      "permissions": ["android.permission.INTERNET", "android.permission.POST_NOTIFICATIONS"]
    },
    "plugins": ["expo-notifications"],
    "extra": {
      "eas": {
        "projectId": "BURAYA_EAS_INIT_CALISTIRINCA_OTOMATIK_GELECEK"
      }
    }
  }
}
