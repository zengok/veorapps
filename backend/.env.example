# ═══════════════════════════════════════════════
# Veor Collection API – Environment Configuration
# ═══════════════════════════════════════════════

# ── Server ──────────────────────────────────────
PORT=3000
NODE_ENV=development        # development | staging | production

# ── JWT Auth (use long random strings in production!) ──
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Database (PostgreSQL) ───────────────────────
# For production, use DATABASE_URL. For local dev use individual vars.
DATABASE_URL=postgres://postgres:veor@localhost:5432/veor_prod
DB_HOST=127.0.0.1
DB_NAME=veor_dev
DB_USER=postgres
DB_PASSWORD=veor

# ── CORS ────────────────────────────────────────
# Set to your frontend origin in production (e.g., https://app.yourdomain.com)
CORS_ORIGIN=*

# ── Rate Limiting ───────────────────────────────
# Comma-separated IP whitelist to bypass rate limits (e.g. your internal server)
RATE_LIMIT_WHITELIST=127.0.0.1,::1

# ── Security ────────────────────────────────────
# Max failed login attempts before account lockout
MAX_FAILED_ATTEMPTS=5
# Lock duration in minutes
LOCKOUT_DURATION_MINUTES=15
